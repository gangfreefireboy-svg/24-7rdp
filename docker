FROM ubuntu:22.04

ENV DEBIAN_FRONTEND=noninteractive

RUN apt update && apt install -y \
    xfce4 \
    xfce4-goodies \
    xrdp \
    sudo \
    wget \
    curl \
    dbus-x11 \
    x11-xserver-utils

RUN useradd -m railway && echo "railway:railway" | chpasswd
RUN adduser railway sudo

RUN echo "startxfce4" > /home/railway/.xsession
RUN chown railway:railway /home/railway/.xsession

EXPOSE 3389

CMD service xrdp start && tail -f /dev/null
